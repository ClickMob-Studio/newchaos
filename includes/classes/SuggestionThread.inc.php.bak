<?phpDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->queryDBi::$conn->query



final class SuggestionThread extends BaseObject {

	static $idField = 'id';

	static $dataTable = 'suggestion_threads';

	

	protected static function GetDataTable()

	{

		return self::$dataTable;

	}

		

	protected static function GetDataTableFields()

	{

		return array(

			self::$idField,

			'author',

			'title',

			'level',

			'category',

			'closed',

			'closedby',

			'closedate',

			'score',

			'creationdate',

			'updateauthor',

			'updatedate'

		);

	}

	

	protected function GetIdentifierFieldName()

	{

		return self::$idField;

	}

	

	protected function GetClassName()

	{

		return __CLASS__;

	}

	

	static public function sOpen($authorId, $title, $text, $level, $category = 1)

	{

		$tid = self::sAdd($authorId, $title, $level, $category);

		SuggestionEntry::sAdd($tid, $authorId, $text);

		return $tid;

	}

	

	static public function sColorizeScore($score)

	{

		if ($score < 0)

			return '<font color="#CC0000"><b>'.$score.'</b></font>';

		else if ($score > 0)

			return '<font color="#669900"><b>'.$score.'</b></font>';

		return '<font color="#CCCC00"><b>'.$score.'</b></font>';

	}

	

	public function IsClosed()

	{

		if ($this->closed == 1)

			return true;

		return false;

	}

	

	public function HasVoted(User $user)

	{

		$query = 'SELECT `User` FROM `suggestion_threads_votes` WHERE `User` = \''.$user->id.'\' AND `Thread` = \''.$this->id.'\'';

		$res = DBi::$conn->query($query);

		if (mysqli_num_rows($res) >= 1)

			return true;

		return false;

	}

	

	static public function sHasVoted($tid, User $user)

	{

		$query = 'SELECT `User` FROM `suggestion_threads_votes` WHERE `User` = \''.$user->id.'\' AND `Thread` = \''.$tid.'\'';

		$res = DBi::$conn->query($query);

		if (mysqli_num_rows($res) >= 1)

			return true;

		return false;

	}

	

	public function AddVote(User $user, $vote = 0)

	{

		if ($this->HasVoted($user) === true)

			throw new FailedResult('Your vote has already been given for this suggestion.');

		DBi::$conn->query('INSERT INTO `suggestion_threads_votes` (`User`, `Thread`, `Vote`) VALUES (\''.$user->id.'\', \''.$this->id.'\', \''.$vote.'\')');

		if (DBi::$conn -> affected_rows == 0)

			throw new SoftException('Your vote could not be added. Please try again later.');

		if ($vote > 0)

			$this->AddToAttribute('score', $vote);

		else if ($vote < 0)

			$this->ForceRemoveFromAttribute('score', -$vote);

		return true;

	}

	

	public function DeleteVote(User $user)

	{

		DBi::$conn->query('DELETE FROM `suggestion_threads_votes` WHERE `User` = \''.$user->id.'\' AND `Thread` = \''.$this->id.'\' LIMIT 1');

		if (DBi::$conn -> affected_rows == 0)

			throw new SoftException('Your vote could not be deleted. Please try again later.');

		return true;

	}

	

	public function IsAccessibleTo(User $user)

	{

		if ($user->id != $this->author

			&& $this->IsClosed() === true

			&& $this->IsAccessibleToSupportUser($user->GetSupportStatus()) === false)

			return false;

		return true;

	}

	

	public function IsAccessibleToSupportUser($suser)

	{

		if ($suser === null)

			return false;

		else if ($suser->GetLevel() < $this->level)

			return false;

		return true;

	}

	

	public function ChangeCategory(User $user, $category)

	{

		if ($category <= 0)

			throw new SoftException('Invalid category.', 'edit');

		else if ($user->id != $this->author

			&& SupportUser::HasSUserAccess($user->id, $this->level) === false)

			throw new SoftException('You cannot change category for a support request you did not create.', 'edit');

		$this->SetAttribute('category', $category);

		return true;

	}



	public function Reopen(User $user)

	{

		if ($this->closed == 0)

			throw new SoftException('You cannot reopen a support request that is already opened.', 'opened');

		else if ($user->id != $this->author

			&& SupportUser::HasSUserAccess($user->id, $this->level) === false)

			throw new SoftException('You cannot reopen a support request you did not create.', 'opened');

		$this->SetAttribute('closed', 0);

		$this->SetNullAttribute('closedby');

		return true;

	}

	

	public function Close(User $user)

	{

		if ($this->closed == 1)

			throw new SoftException('You cannot close a support request that is already closed.', 'opened');

		else if ($this->IsAccessibleTo($user) === false)

			throw new SoftException('You cannot close a support request you did not create.', 'opened');

		$this->SetAttribute('closed', 1);

		$this->SetAttribute('closedby', $user->id);

		$this->SetAttribute('closedate', time());

		if ($this->author != $user->id)

		{

			$author = UserFactory::getInstance()->getUser($this->author);

			$author->Notify('Your suggestion #'.$this->id.' was closed.', 'Suggestion');

		}

		return true;

	}

	

	public function Promote(User $user)

	{

		if ($user->GetSupportStatus()->HasAccess(2) === false 

		&& $this->IsAccessibleToSupportUser($user->GetSupportStatus()) === false)

			throw new SoftException('You do not have access to this support request.', 'sopened');

		else if ($this->level >= 3)

			throw new SoftException('You cannot promote a thread to a level higher than 3.', 'sopened');

		$promMsg = '';

		if ($this->level == 1)

			$promMsg = 'It means it will get reviewed by the admin team for integration and final decision.';

		else if ($this->level == 2)

			$promMsg = 'It means the suggestion will be integrated into the game ! Congratulations !.';

		User::SNotify($this->author, 'Your suggestion #'.$this->id.' have been promoted to level '.($this->level + 1).' ! '.$promMsg, 'Suggestion');

		return $this->AddToAttribute('level', 1);

	}

	

	public function Demote(User $user)

	{

		if ($user->GetSupportStatus()->HasAccess(2) === false 

		&& $this->IsAccessibleToSupportUser($user->GetSupportStatus()) === false)

			throw new SoftException('You do not have access to this support request.', 'sopened');

		else if ($this->level <= 1)

			throw new SoftException('You cannot demote a thread to a level lower than 1.', 'sopened');

		return $this->RemoveFromAttribute('level', 1);

	}

	

	static public function CountAllOpenedForLevel($level, $uid = null)

	{

		if ($uid !== null)

			$res = DBi::$conn->query('SELECT COUNT(`id`) AS total FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `author`=\''.$uid.'\' AND `closed`=0');

		else

			$res = DBi::$conn->query('SELECT COUNT(`id`) AS total FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `closed`=0');

		if ($res->num_rows == 0)

			return 0;

		$obj = mysqli_fetch_object($res);

		return $obj->total;

	}

	

	public function GetMostRecentEntry()

	{

		return SuggestionEntry::GetMostRecentForThread($this->id);

	}

	

	static public function GetAllOpenedForLevelByScore($level, $start = 0, $limit = 10, $uid = null, $search = array())

	{

		$objs = array();

		$where = "";

		if(isset($search['category']) && !empty($search['category']))

			$where .= ' AND category = '.$search['category'];



		if ($uid !== null)

			$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `author`=\''.$uid.'\' AND `closed`=0 '.$where.' ORDER BY `level` DESC, `score` DESC, `updatedate` DESC LIMIT '.$start.', '.$limit);

		else

			$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `closed`=0 '.$where.' ORDER BY `level` DESC, `score` DESC, `updatedate` DESC LIMIT '.$start.', '.$limit);

		if ($res->num_rows == 0)

			return null;

		while ($obj = mysqli_fetch_object($res))

			$objs[] = $obj;

		return $objs;

	}

	

	static public function GetAllOpenedForLevelByTime($level, $start = 0, $limit = 10, $uid = null, $search = array())

	{

		$objs = array();

		$where = "";

		if(isset($search['category']) && !empty($search['category']))

			$where .= ' AND category = '.$search['category'];



		if ($uid !== null)

			$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `author`=\''.$uid.'\' AND `closed`=0 '.$where.' ORDER BY `level` DESC, `creationdate` DESC, `score` DESC LIMIT '.$start.', '.$limit);

		else

			$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `closed`=0 '.$where.' ORDER BY `level` DESC, `creationdate` DESC, `score` DESC LIMIT '.$start.', '.$limit);

		if ($res->num_rows == 0)

			return null;

		while ($obj = mysqli_fetch_object($res))

			$objs[] = $obj;

		return $objs;

	}

	

	static public function CountAllOpenedForAuthor($authorId)

	{

		$res = DBi::$conn->query('SELECT COUNT(`id`) AS total FROM `'.self::$dataTable.'` WHERE `author` = \''.$authorId.'\' AND `closed`=0');

		if ($res->num_rows == 0)

			return 0;

		$obj = mysqli_fetch_object($res);

		return $obj->total;

	}

	

	static public function GetAllOpenedForAuthor($authorId, $start = 0, $limit = 10, $search = array())

	{

		$i = 0;

		$objs = array();

		

		$where = "";

		if(isset($search['category']) && !empty($search['category']))

			$where .= ' AND category = '.$search['category'];



		$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `author` = \''.$authorId.'\' AND `closed`=0 '.$where.' ORDER BY `level` DESC, `updatedate` DESC LIMIT '.$start.', '.$limit);

		if ($res->num_rows == 0)

			return null;

		while ($obj = mysqli_fetch_object($res))

			$objs[$i++] = $obj;

		return $objs;

	}

	

	static public function CountAllClosedForLevel($level, $uid = null)

	{

		if ($uid !== null)

			$res = DBi::$conn->query('SELECT COUNT(`id`) AS total FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `author`=\''.$uid.'\' AND `closed`=1');

		else

			$res = DBi::$conn->query('SELECT COUNT(`id`) AS total FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `closed`=1');

		if ($res->num_rows == 0)

			return 0;

		$obj = mysqli_fetch_object($res);

		return $obj->total;

	}

	

	static public function GetAllClosedForLevel($level, $start = 0, $limit = 10, $uid = null, $search = array())

	{

		$i = 0;

		$objs = array();

		$where = "";

		if(isset($search['category']) && !empty($search['category']))

			$where .= ' AND category = '.$search['category'];



		if ($uid !== null)

			$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `author`=\''.$uid.'\' AND `closed`=1 '.$where.' ORDER BY `level` DESC, `score` DESC, `updatedate` DESC LIMIT '.$start.', '.$limit);

		else

			$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `level` <= \''.$level.'\' AND `closed`=1 '.$where.' ORDER BY `level` DESC, `score` DESC, `updatedate` DESC LIMIT '.$start.', '.$limit);



		

		if ($res->num_rows == 0)

			return null;

		while ($obj = mysqli_fetch_object($res))

			$objs[$i++] = $obj;

		return $objs;

	}

	

	static public function CountAllClosedForAuthor($authorId)

	{

		$res = DBi::$conn->query('SELECT COUNT(`id`) AS total FROM `'.self::$dataTable.'` WHERE `author` = \''.$authorId.'\' AND `closed`=1');

		if ($res->num_rows == 0)

			return 0;

		$obj = mysqli_fetch_object($res);

		return $obj->total;

	}

	

	static public function GetAllClosedForAuthor($authorId, $start = 0, $limit = 10, $search = array())

	{

		$i = 0;

		$objs = array();

		$where = "";

		if(isset($search['category']) && !empty($search['category']))

			$where .= ' AND category = '.$search['category'];



		$res = DBi::$conn->query('SELECT `'.implode('`, `', self::GetDataTableFields()).'` FROM `'.self::$dataTable.'` WHERE `author` = \''.$authorId.'\' AND `closed`=1 '.$where.' ORDER BY `updatedate` DESC LIMIT '.$start.', '.$limit);

		if ($res->num_rows == 0)

			return null;

		while ($obj = mysqli_fetch_object($res))

			$objs[$i++] = $obj;

		return $objs;

	}

	

	static private function sAdd($authorId, $title, $level, $category=1)

	{

		DBi::$conn->query('INSERT INTO `'.self::$dataTable.'` (`author`, `title`, `level`, `category`, `creationdate`, `updateauthor`, `updatedate`) VALUES (\'' . $authorId . '\',\'' . $title . '\',\'' . $level . '\',\'' . $category . '\', \''.time().'\', \'' . $authorId . '\',  \''.time().'\')');

		if (DBi::$conn -> affected_rows == 0)

			throw new SoftException('The thread could not be added. Please try again later and contact an administrator.', 'opened');

		return DBi::$conn -> insert_id;

	}

	

	public function Delete(User $user)

	{

		if ($user->id != $this->author

			&& $this->IsAccessibleToSupportUser($user->GetSupportStatus()) === false)

			throw new SoftException('You cannot delete a suggestion you did not submit.', 'opened');

		DBi::$conn->query('DELETE FROM `'.self::$dataTable.'` WHERE `id`=\''.$this->id.'\'');

		if (DBi::$conn -> affected_rows == 0)

			throw new SoftException('The thread could not be deleted. Please try again later and contact an administrator.', 'opened');

		if ($this->author != $user->id)

		{

			$author = UserFactory::getInstance()->getUser($this->author);

			$author->Notify('Your suggestion #'.$this->id.' was deleted. Please open a support ticket if you have any questions.', 'Suggestion');

		}

		return true;

	}

	

	public function Reply(User $user, $text)

	{

		if ($this->closed == true && $user->IsSupportUser() === false)

			throw new SoftException('You cannot reply to a closed thread.', 'opened');

		else if ($this->IsAccessibleTo($user) === false)

			throw new SoftException('You cannot reply to this suggestion.', 'opened');

		$this->SetAttribute('updatedate', time());

		$this->SetAttribute('updateauthor', $user->id);

		SuggestionEntry::sAdd($this->id, $user->id, $text);

		if ($this->author != $user->id) // You can add events here to notify the author

			$author = UserFactory::getInstance()->getUser($this->author);

		return true;

	}

}



?>

