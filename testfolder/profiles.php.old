    $profile_class->lastactive = 1;
    $profile_class->age = lastactive(1454713796 - 30000, 'days');
    $profile_class->formattedonline = "<font style='color:green;padding:2px;font-weight:bold;'>[online]</font>";
}
if (isset($_POST['5ips']))
