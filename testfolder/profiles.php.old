            <script>
                function postOnWall() {
                    if ($('#reply').val() != '') {
                        $.post("ajax_wall.php", {'msg': $('#reply').val(), 'uid':<?php
                    echo $profile_class->id;
                    ?>}, function (d) {
                            $('#comments tr:last').after(d);
                            $('#reply').val('');
                            $('#reply').focus();
                        });
                    }
                    return false;
                }
                function delMyWall(wallid) {
                    $.post("ajax_delwall.php", {'id': wallid}, function (d) {
                        $("#id" + wallid).css("display", "none");
                    });
                }
                $("#div1").animate({scrollTop: $('#div1').prop("scrollHeight")}, 100);
            </script>
            <div style='height:30px;width:100%;text-align:center;'>
                <table style='margin:0 auto;'><tr><td><input type='text' size='30' maxlength='60' name='msg' id='reply' /></td><td><button style='white-space:nowrap;' onclick='postOnWall();'>Post Message</button></td></tr></table>
