{
    "name": "chaoscity/sendinblue-php56",
    "description": "Sendinblue API client for PHP 5.6",
    "keywords": [
        "sendinblue",
        "api",
        "php",
        "email"
    ],
    "license": "MIT",
    "require": {
        "php": ">=5.6",
        "ext-json": "*",
        "guzzlehttp/guzzle": "~6.0",
        "sendinblue/api-v3-sdk": "2.0.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^5",
        "php-coveralls/php-coveralls": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "chaoscity\\": "src/"
        }
    },
    "config": {
        "platform": {
            "php": "5.6.0"
        }
    }
}